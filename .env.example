# API base — must end up as .../api (see apiConfig.js)
# Production:
VITE_API_URL=https://api.vyaharam.com
#
# Alternative: same-origin proxy in dev (Vite `server.proxy` in vite.config.js)
# VITE_API_URL=/api

# Same as backend OTP_CODE_LENGTH (e.g. 6 for Tallwin WhatsApp template)
# VITE_OTP_LENGTH=6

# Admin login mobile (10 digits, must match backend ADMIN_PHONE)
# VITE_ADMIN_PHONE=8299393771

# Paytm checkout uses your backend /api/payment/paytm-initiate (no extra Vite keys required).
# For sandbox callbacks from Paytm’s servers, use ngrok (or similar) and set backend PAYTM_CALLBACK_URL — see project notes.

# Google Maps Platform — browser key for Maps JavaScript API (@react-google-maps/api: LiveMap, markers, Directions).
# Enable: Maps JavaScript API, Directions API, Geocoding API, Places API (Rider map nearby landmarks). Restrict by HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=
